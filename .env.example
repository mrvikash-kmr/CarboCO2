# VITE_GEMINI_API_KEY: Required for Gemini AI API calls (client-side)
# Must be prefixed with VITE_ to be accessible in the browser
# Get your key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# PAGESPEED_API_KEY: Required for Google PageSpeed Insights API (server-side)
# Get your key from: https://console.cloud.google.com/
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# MONGODB_URI: Required for user authentication and storing scan history
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=your_mongodb_connection_string

# JWT_SECRET: Required for securing authentication tokens
JWT_SECRET=your_jwt_secret_key_here

# NODE_ENV: Set to 'production' for deployment, 'development' for local development
NODE_ENV=development
